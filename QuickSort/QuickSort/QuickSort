import random

def partition(arr, low, high):
    # Разделение по схеме Ломуто
    pivot = arr[high] #опорный элемент
    i = low - 1 #граница элементов
    for j in range(low, high):
        if arr[j] <= pivot:
            i += 1
            arr[i], arr[j] = arr[j], arr[i]
    arr[i + 1], arr[high] = arr[high], arr[i + 1] #смена мест элементов
    return i + 1

def randomized_partition(arr, low, high): 
    rand_index = random.randint(low, high) #рандомизация
    arr[rand_index], arr[high] = arr[high], arr[rand_index]
    return partition(arr, low, high)

def quick_sort(arr, low, high): #сортировка
    if low < high:
        pi = randomized_partition(arr, low, high)
        #сортировка левой и правой части
        quick_sort(arr, low, pi - 1)
        quick_sort(arr, pi + 1, high)
